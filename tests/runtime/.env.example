# Runtime smoke test env example.
# Copy to tests/runtime/.env or set TEST_ENV_FILE to another env file.

# Public gateway URL. Can be http or https.
TEST_SUPABASE_URL=http://your-supabase-domain.example

# Legacy JWT keys.
TEST_ANON_KEY=replace_with_anon_jwt
TEST_SERVICE_ROLE_KEY=replace_with_service_role_jwt

# Modern opaque keys. Optional but recommended; tests use them when present.
TEST_PUBLISHABLE_KEY=sb_publishable_replace_me
TEST_SECRET_KEY=sb_secret_replace_me

# Studio basic-auth values, reserved for future dashboard-specific tests.
TEST_DASHBOARD_USERNAME=supabase
TEST_DASHBOARD_PASSWORD=replace_with_dashboard_password

# Match the previous curl -k behavior for test environments.
TEST_TLS_INSECURE=true
