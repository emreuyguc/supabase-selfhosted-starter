# Core public URLs
CONTAINER_PREFIX=supabase
SUPABASE_PUBLIC_URL=http://supabase.example.com
ADDITIONAL_REDIRECT_URLS=http://supabase.example.com/*

# External Postgres and pooling
POSTGRES_PASSWORD=replace_with_external_postgres_password
SERVICE_PASSWORD_POSTGRES=replace_with_external_postgres_password
POSTGRES_HOST=db.example.com
POSTGRES_HOSTNAME=db.example.com
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_DB_OWNER=supabase_admin
POSTGRES_BOOTSTRAP_DB=postgres
POSTGRES_BOOTSTRAP_USER=postgres
POSTGRES_BOOTSTRAP_PASSWORD=replace_with_external_postgres_admin_password
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=external_tenant
POOLER_POOL_MODE=transaction
POOLER_DB_POOL_SIZE=5

# JWT and API keys
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
SERVICE_PASSWORD_JWT=change_me_jwt_secret_at_least_32_chars_long
ANON_KEY=replace_with_anon_jwt_signed_by_jwt_secret
SERVICE_SUPABASEANON_KEY=replace_with_anon_jwt_signed_by_jwt_secret
SERVICE_ROLE_KEY=replace_with_service_role_jwt_signed_by_jwt_secret
SERVICE_SUPABASESERVICE_KEY=replace_with_service_role_jwt_signed_by_jwt_secret
SUPABASE_PUBLISHABLE_KEY=sb_publishable_change_me_opaque_public_key
SUPABASE_SECRET_KEY=sb_secret_change_me_opaque_secret_key
JWT_EXPIRY=3600

# Dashboard and Studio
DASHBOARD_USERNAME=supabase
SERVICE_USER_ADMIN=supabase
DASHBOARD_PASSWORD=change_me_dashboard_password_32_chars
SERVICE_PASSWORD_ADMIN=change_me_dashboard_password_32_chars
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=

# Analytics and logging
LOGFLARE_PUBLIC_ACCESS_TOKEN=change_me_logflare_public_token_32_chars
LOGFLARE_PRIVATE_ACCESS_TOKEN=change_me_logflare_private_token_32_chars
SERVICE_PASSWORD_LOGFLARE=change_me_logflare_public_token_32_chars
SERVICE_PASSWORD_LOGFLAREPRIVATE=change_me_logflare_private_token_32_chars
LOGFLARE_API_KEY=change_me_logflare_public_token_32_chars
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Internal encryption secrets
SECRET_KEY_BASE=change_me_secret_key_base_64_characters_minimum_value
VAULT_ENC_KEY=change_me_vault_encryption_key_32
PG_META_CRYPTO_KEY=change_me_pg_meta_crypto_key_32
SERVICE_PASSWORD_PGMETACRYPTO=change_me_pg_meta_crypto_key_32
REALTIME_DB_ENC_KEY=change_me_16_chars
SERVICE_PASSWORD_SUPAVISORSECRET=change_me_secret_key_base_64_characters_minimum_value
SERVICE_PASSWORD_VAULTENC=change_me_vault_encryption_key_32

# Storage and MinIO
S3_PROTOCOL_ACCESS_KEY_ID=change_me_s3_access_key_id_32_chars
S3_PROTOCOL_ACCESS_KEY_SECRET=change_me_s3_access_key_secret_64_chars
MINIO_ROOT_USER=supabase
MINIO_ROOT_PASSWORD=change_me_minio_root_password_32_chars
IMGPROXY_ENABLE_WEBP_DETECTION=true
IMGPROXY_AUTO_WEBP=true
STORAGE_S3_BUCKET=supabase-storage
STORAGE_S3_REGION=us-east-1
STORAGE_TENANT_ID=stub

# PostgREST
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# Auth signup and mail
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=false
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
MAILER_TEMPLATES_INVITE=
MAILER_TEMPLATES_CONFIRMATION=
MAILER_TEMPLATES_RECOVERY=
MAILER_TEMPLATES_MAGIC_LINK=
MAILER_TEMPLATES_EMAIL_CHANGE=
MAILER_SUBJECTS_INVITE=You have been invited
MAILER_SUBJECTS_CONFIRMATION=Confirm your signup
MAILER_SUBJECTS_RECOVERY=Reset your password
MAILER_SUBJECTS_MAGIC_LINK=Your magic link
MAILER_SUBJECTS_EMAIL_CHANGE=Confirm email change

# Edge Functions
FUNCTIONS_VERIFY_JWT=false

# Kong tuning
KONG_STORAGE_CONNECT_TIMEOUT=60
KONG_STORAGE_WRITE_TIMEOUT=3600
KONG_STORAGE_READ_TIMEOUT=3600
KONG_STORAGE_REQUEST_BUFFERING=false
KONG_STORAGE_RESPONSE_BUFFERING=false
